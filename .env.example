# Copy to .env and fill in real values. NEVER commit .env (see .gitignore).
# Every variable here maps to a field on common.settings.Settings (SPEC §10.5).

# --- LLM providers ---
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx           # fallback only

# --- Embeddings & reranking ---
VOYAGE_API_KEY=pa-xxxxxxxxxxxxxxxxxxxxxxxx
COHERE_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxx

# --- Vector store (Qdrant) ---
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=                                       # blank for local self-hosted

# --- Observability (LangSmith) ---
LANGSMITH_API_KEY=lsv2_xxxxxxxxxxxxxxxxxxxxxxxx
LANGSMITH_PROJECT=knowledge-agent

# --- Graph store (Phase 3) ---
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme

# --- Cache backends ---
EMBEDDING_CACHE_PATH=.cache/embeddings.sqlite
